# ────────────────────────────────────────────────────────────────────────────
# FinAgentFlow — Environment Configuration
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your API keys.
#   cp .env.example .env

# ── Application ───────────────────────────────────────────────────────────
APP_NAME=FinAgentFlow
DEBUG=false
LOG_LEVEL=INFO

# ── EuriAI API Key (REQUIRED) ────────────────────────────────────────────
# Get your EuriAI key at: https://euron.one
EURI_API_KEY=your-euri-api-key-here

# ── EuriAI Settings ──────────────────────────────────────────────────────
EURI_MODEL=gpt-4.1-nano
EURI_TEMPERATURE=0.3
EURI_MAX_TOKENS=2048
EURI_RETRY_ATTEMPTS=3
EURI_RETRY_DELAY=1.0

# ── FastAPI Backend ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# SQLITE_URL=sqlite:///data/finagentflow.db

# ── Streamlit Frontend ───────────────────────────────────────────────────
STREAMLIT_PORT=8501
